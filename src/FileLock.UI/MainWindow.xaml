<Window x:Class="FileLock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileLock"
        Width="440" Height="380"
        MinWidth="440" MinHeight="380"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragOver"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        FontFamily="Segoe UI"
        Background="#F3F4F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- title -->
            <RowDefinition Height="*" />
            <!-- drop zone -->
            <RowDefinition Height="Auto" />
            <!-- password -->
            <RowDefinition Height="Auto" />
            <!-- status -->
            <RowDefinition Height="Auto" />
            <!-- footer / warning -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🔒" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="FileLock" FontSize="20" FontWeight="SemiBold"
                       Foreground="#111827" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Drop zone -->
        <Border x:Name="DropZone" Grid.Row="1"
                BorderBrush="#9CA3AF" BorderThickness="2"
                Background="#FFFFFF" CornerRadius="10"
                Margin="0,0,0,14">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⬇" FontSize="34" HorizontalAlignment="Center"
                               Foreground="#6B7280" Margin="0,0,0,6" />
                    <TextBlock x:Name="DropHint"
                               Text="Drop a file here to lock or unlock"
                               FontSize="14" Foreground="#374151"
                               HorizontalAlignment="Center" TextAlignment="Center" />
                    <TextBlock Text="Locked files end in .locked"
                               FontSize="11" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Password -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Password" FontSize="12" Foreground="#374151" Margin="2,0,0,4" />
            <PasswordBox x:Name="PasswordInput" Padding="6,5" FontSize="14"
                         Background="#FFFFFF" BorderBrush="#9CA3AF" />
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   Text="Ready."
                   FontSize="12" Foreground="#374151"
                   TextWrapping="Wrap" MinHeight="32"
                   VerticalAlignment="Center" Margin="2,0,0,0" />

        <!-- Footer warning -->
        <TextBlock Grid.Row="4" FontSize="11" Foreground="#9CA3AF"
                   TextWrapping="Wrap" Margin="2,4,0,0"
                   Text="⚠ If you forget your password, the file cannot be recovered. There is no backdoor." />
    </Grid>
</Window>

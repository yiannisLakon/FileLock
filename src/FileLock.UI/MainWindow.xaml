<Window x:Class="FileLock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileLock"
        Width="460" Height="560"
        MinWidth="460" MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragOver"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        FontFamily="Segoe UI"
        Background="#F3F4F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- title -->
            <RowDefinition Height="Auto" />
            <!-- password card -->
            <RowDefinition Height="*" />
            <!-- drop zone -->
            <RowDefinition Height="Auto" />
            <!-- status -->
            <RowDefinition Height="Auto" />
            <!-- storage + warning -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🔒" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="FileLock" FontSize="20" FontWeight="SemiBold"
                       Foreground="#111827" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Password card -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="10" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Default password" FontSize="13" FontWeight="SemiBold"
                           Foreground="#111827" Margin="0,0,0,2" />
                <TextBlock Text="Used for every lock and unlock. Stored encrypted in this app's folder."
                           FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,8" />

                <TextBlock Text="Password" FontSize="12" Foreground="#374151" Margin="2,0,0,3" />
                <PasswordBox x:Name="PasswordInput" Padding="6,5" FontSize="14"
                             Background="#FFFFFF" BorderBrush="#9CA3AF" Margin="0,0,0,8" />

                <TextBlock Text="Confirm password" FontSize="12" Foreground="#374151" Margin="2,0,0,3" />
                <PasswordBox x:Name="ConfirmInput" Padding="6,5" FontSize="14"
                             Background="#FFFFFF" BorderBrush="#9CA3AF" Margin="0,0,0,10" />

                <Button x:Name="SaveButton" Content="Save password" Click="SaveButton_Click"
                        HorizontalAlignment="Right" Padding="14,6" />
            </StackPanel>
        </Border>

        <!-- Drop zone -->
        <Border x:Name="DropZone" Grid.Row="2"
                BorderBrush="#9CA3AF" BorderThickness="2"
                Background="#FFFFFF" CornerRadius="10"
                Margin="0,0,0,12" MinHeight="120">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⬇" FontSize="30" HorizontalAlignment="Center"
                               Foreground="#6B7280" Margin="0,0,0,6" />
                    <TextBlock Text="Drop a file here to lock or unlock"
                               FontSize="14" Foreground="#374151"
                               HorizontalAlignment="Center" TextAlignment="Center" />
                    <TextBlock Text="Files toggle in place — locked files are unlocked, others are locked."
                               FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap" MaxWidth="360"
                               HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   Text="Ready."
                   FontSize="12" Foreground="#374151"
                   TextWrapping="Wrap" MinHeight="32"
                   VerticalAlignment="Center" Margin="2,0,0,0" />

        <!-- Storage + warning -->
        <StackPanel Grid.Row="4" Margin="2,2,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button x:Name="OpenFolderButton" Content="Open backup folder"
                        Click="OpenFolderButton_Click" Padding="10,4" FontSize="11" />
                <TextBlock x:Name="StorageHint" VerticalAlignment="Center" Margin="10,0,0,0"
                           FontSize="11" Foreground="#9CA3AF" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap"
                       Text="⚠ If you forget your password, locked files cannot be recovered. There is no backdoor." />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="FileLock.UI.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileLock"
        Width="390" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        FontFamily="Segoe UI"
        Background="#F3F4F6">

    <StackPanel Margin="20">
        <TextBlock Text="🔒 Set your password" FontSize="16" FontWeight="SemiBold"
                   Foreground="#111827" Margin="0,0,0,4" />
        <TextBlock Text="You'll use this password every time you lock or unlock a file. Keep it safe — if you forget it, locked files cannot be recovered."
                   FontSize="11" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,14" />

        <TextBlock Text="Password" FontSize="12" Foreground="#374151" Margin="0,0,0,3" />
        <PasswordBox x:Name="PasswordInput" Padding="6,5" FontSize="14"
                     Background="#FFFFFF" BorderBrush="#9CA3AF" Margin="0,0,0,8" />

        <TextBlock Text="Confirm password" FontSize="12" Foreground="#374151" Margin="0,0,0,3" />
        <PasswordBox x:Name="ConfirmInput" Padding="6,5" FontSize="14"
                     Background="#FFFFFF" BorderBrush="#9CA3AF" Margin="0,0,0,8" />

        <TextBlock x:Name="ErrorText" Foreground="#B91C1C" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,6" Margin="0,0,8,0" />
            <Button Content="Save password" IsDefault="True" Padding="14,6" Click="Save_Click" />
        </StackPanel>
    </StackPanel>
</Window>
